# Server-side key for /api/parse-rule (production on Vercel)
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Optional: override Groq model (default: openai/gpt-oss-20b)
# GROQ_MODEL=openai/gpt-oss-20b

# Optional: client-side key for local `npm run dev` without `vercel dev`
# VITE_GROQ_API_KEY=gsk_your_key_here
# VITE_GROQ_MODEL=openai/gpt-oss-20b